# Copy to .env and fill in. Never commit the real .env.

# Django secret (generate a random string for production)
SECRET_KEY=dev-insecure-change-me

# Admin superusers — comma-separated. All get created/synced with ADMIN_PASSWORD on boot.
ADMIN_EMAILS=you@example.com
ADMIN_PASSWORD=change-me

# OpenRouteService API key — free at https://openrouteservice.org (needed from Slice 3)
ORS_API_KEY=

# Production subpath (leave unset in dev)
# SCRIPT_NAME=/spotter
# DEBUG=0
